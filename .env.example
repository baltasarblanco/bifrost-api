# --- DATABASE CONFIG ---
POSTGRES_USER=ronin
POSTGRES_PASSWORD=helados_fuente
POSTGRES_DB=bifrost_db
# Dentro de Docker Compose (usa hostname del servicio):
DATABASE_URL=postgresql://ronin:helados_fuente@db:5432/bifrost_db
# Local (uvicorn en el host) — descomentar si corrés sin compose:
# DATABASE_URL=postgresql://ronin:helados_fuente@127.0.0.1:5433/bifrost_db

# --- REDIS CONFIG ---
REDIS_PASSWORD=change_me_to_a_strong_password
# Dentro de Docker Compose:
REDIS_URL=redis://:change_me_to_a_strong_password@redis:6379/0
# Local (uvicorn en el host):
# REDIS_URL=redis://:change_me_to_a_strong_password@127.0.0.1:6380/0

# --- SECURITY ---
SECRET_KEY=your_super_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- AI PROVIDERS ---
GOOGLE_API_KEY=your_gemini_api_key_here

# --- ENVIRONMENT ---
ENVIRONMENT=development